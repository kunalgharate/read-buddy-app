# Files and directories created by pub
.dart_tool/
.packages
build/
pubspec.lock

# Directory created by dartdoc
doc/api/

# dotenv environment variables file
.env*

# Avoid committing generated Javascript files:
*.dart.js
*.info.json
*.js
*.js_
*.js.deps
*.js.map

# Flutter
.flutter-plugins
.flutter-plugins-dependencies

# IDE files
.idea/
*.iml

# OS files
.DS_Store

# Android build artifacts & generated files
android/app/.cxx/
android/.gradle/
android/app/build/
android/build/
android/local.properties
*.log

# Assets mock data
assets/mock/
