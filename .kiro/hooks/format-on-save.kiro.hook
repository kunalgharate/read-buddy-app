{
  "enabled": true,
  "name": "Dart Format on Save",
  "description": "Runs dart format on Dart source files when saved.",
  "version": "1.0.0",
  "when": {
    "type": "fileEdited",
    "patterns": ["lib/**/*.dart"]
  },
  "then": {
    "type": "runCommand",
    "command": "dart format lib/"
  }
}